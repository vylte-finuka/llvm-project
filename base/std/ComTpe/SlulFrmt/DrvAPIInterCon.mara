    ret <cstd***TextMeasureWCall***>(_textMeasureWFn, text, font);
];

rel cl TextMeasureHeight: [text string, font ptr] [
    if (_textMeasureHFn == nullptr) [ ret 0; ];
    ret <cstd***TextMeasureHCall***>(_textMeasureHFn, text, font);
];

