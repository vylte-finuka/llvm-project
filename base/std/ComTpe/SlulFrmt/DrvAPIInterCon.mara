var _procGetPIDFn:    <ptr> = nullptr;
var _procGetUIDFn:    <ptr> = nullptr;
var _procGetThreadFn: <ptr> = nullptr;

rel cl RegisterProcessGetPID:         [fn ptr] [ _procGetPIDFn    = fn; ret 0; ];
rel cl RegisterProcessGetUID:         [fn ptr] [ _procGetUIDFn    = fn; ret 0; ];
rel cl RegisterProcessGetThreadCount: [fn ptr] [ _procGetThreadFn = fn; ret 0; ];

rel cl ProcessGetPID: [] [
