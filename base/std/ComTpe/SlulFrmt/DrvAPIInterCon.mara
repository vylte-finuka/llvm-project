// SensorRead – lecture générique d'un capteur par identifiant numérique
var _sensorReadFn: <ptr> = nullptr;

rel cl RegisterSensorRead: [fn ptr] [ _sensorReadFn = fn; ret 0; ];

rel cl SensorRead: [sensorId i32] [
    if (_sensorReadFn == nullptr) [ ret 0; ];
    ret <cstd***SensorReadCall***>(_sensorReadFn, sensorId);
];

// -----------------------------------------------------------------
// 7. Cryptographie – TRNG, AES-256-GCM, SHA-256, HMAC
// -----------------------------------------------------------------
var _cryptoTRNGFillFn:       <ptr> = nullptr;
var _cryptoAES256GCMEncFn:   <ptr> = nullptr;
var _cryptoSHA256Fn:         <ptr> = nullptr;
var _cryptoHMACSHA256Fn:     <ptr> = nullptr;

rel cl RegisterCryptoTRNGFill:       [fn ptr] [ _cryptoTRNGFillFn     = fn; ret 0; ];
rel cl RegisterCryptoAES256GCMEncrypt:[fn ptr] [ _cryptoAES256GCMEncFn = fn; ret 0; ];
rel cl RegisterCryptoSHA256:         [fn ptr] [ _cryptoSHA256Fn        = fn; ret 0; ];
rel cl RegisterCryptoHMACSHA256:     [fn ptr] [ _cryptoHMACSHA256Fn   = fn; ret 0; ];

rel cl CryptoTRNGFill: [buf ptr, size i32] [
    if (_cryptoTRNGFillFn == nullptr) [ ret -1; ];
    ret <cstd***CryptoTRNGFillCall***>(_cryptoTRNGFillFn, buf, size);
];

rel cl CryptoAES256GCMEncrypt: [key ptr, iv ptr, plaintext ptr, size i32, cipherBuf ptr] [
    if (_cryptoAES256GCMEncFn == nullptr) [ ret -1; ];
    ret <cstd***CryptoAES256GCMEncCall***>(_cryptoAES256GCMEncFn, key, iv, plaintext, size, cipherBuf);
];

rel cl CryptoSHA256: [data ptr, size i32, hashBuf ptr] [
    if (_cryptoSHA256Fn == nullptr) [ ret -1; ];
    ret <cstd***CryptoSHA256Call***>(_cryptoSHA256Fn, data, size, hashBuf);
];

rel cl CryptoHMACSHA256: [key ptr, data ptr, size i32, hmacBuf ptr] [
    if (_cryptoHMACSHA256Fn == nullptr) [ ret -1; ];
    ret <cstd***CryptoHMACSHA256Call***>(_cryptoHMACSHA256Fn, key, data, size, hmacBuf);
];

// -----------------------------------------------------------------
// 8. Processus – spawn, kill, état
// -----------------------------------------------------------------
var _procSpawnFn: <ptr> = nullptr;
var _procKillFn:  <ptr> = nullptr;

rel cl RegisterProcSpawn: [fn ptr] [ _procSpawnFn = fn; ret 0; ];
rel cl RegisterProcKill:  [fn ptr] [ _procKillFn  = fn; ret 0; ];

rel cl ProcSpawn: [bundlePath string, pid i32, prio i32] [
    if (_procSpawnFn == nullptr) [ ret -1; ];
    ret <cstd***ProcSpawnCall***>(_procSpawnFn, bundlePath, pid, prio);
];

rel cl ProcKill: [pid i32] [
    if (_procKillFn == nullptr) [ ret -1; ];
    ret <cstd***ProcKillCall***>(_procKillFn, pid);
];

