//===================================================================
//  DrvAPIInterCon.mara – Driver API Interface Connector
//  Module : base/std/ComTpe/SlulFrmt
//  Auteur : Vyft Ltd
//  Licence : Proprietary – 2026
//  Description :
//      Couche d'abstraction universelle pour accéder aux fonctions
//      matérielles (GPU, CPU, capteurs, fichiers, réseau, ACPI,
//      PCIe, gestion de l'alimentation) et aux APIs logicielles.
//      Les modules enfants enregistrent leurs pointeurs de fonctions
//      via les fonctions Register* ; DrvAPIInterCon reste totalement
//      indépendant du constructeur et réutilisable dans tout contexte.
//===================================================================

#base <MaratineKit>;
#include <cstddef>
#include "llvm/Support/Errc.h"
#include "llvm/Support/raw_ostream.h"

using namespace llvm;

// -----------------------------------------------------------------
// 1. GPU – initialisation, rendu de pixel, flush, HDR, espaces couleur
// -----------------------------------------------------------------
var _gpuInitFn:          <ptr> = nullptr;
var _gpuDrawPixelFn:     <ptr> = nullptr;
var _gpuFlushFn:         <ptr> = nullptr;
var _gpuShutdownFn:      <ptr> = nullptr;
var _gpuSuspendFn:       <ptr> = nullptr;
var _gpuResumeFn:        <ptr> = nullptr;
var _gpuSetColorSpaceFn: <ptr> = nullptr;
var _gpuSetHDRFn:        <ptr> = nullptr;
var _gpuQueryHDRFn:      <ptr> = nullptr;
var _gpuLoadICCFn:       <ptr> = nullptr;
var _gpuGetCapsFn:       <ptr> = nullptr;

rel cl RegisterGpuInit: [fn ptr] [
    _gpuInitFn = fn;
    ret 0;
];

rel cl RegisterGpuDrawPixel: [fn ptr] [
    _gpuDrawPixelFn = fn;
    ret 0;
];

rel cl RegisterGpuFlush: [fn ptr] [
    _gpuFlushFn = fn;
    ret 0;
];

rel cl RegisterGpuShutdown: [fn ptr] [
    _gpuShutdownFn = fn;
    ret 0;
];

rel cl RegisterGpuSuspend: [fn ptr] [
    _gpuSuspendFn = fn;
    ret 0;
];

rel cl RegisterGpuResume: [fn ptr] [
    _gpuResumeFn = fn;
    ret 0;
];

rel cl RegisterGpuSetColorSpace: [fn ptr] [
    _gpuSetColorSpaceFn = fn;
    ret 0;
];

rel cl RegisterGpuSetHDR: [fn ptr] [
    _gpuSetHDRFn = fn;
    ret 0;
];

rel cl RegisterGpuQueryHDR: [fn ptr] [
    _gpuQueryHDRFn = fn;
    ret 0;
];

rel cl RegisterGpuLoadICC: [fn ptr] [
    _gpuLoadICCFn = fn;
    ret 0;
];

rel cl RegisterGpuGetCapabilities: [fn ptr] [
    _gpuGetCapsFn = fn;
    ret 0;
];

rel cl GpuInit: [] [
    if (_gpuInitFn == nullptr) [
        errs() << "DrvAPIInterCon: GpuInit non enregistré\n";
        ret -1;
    ];
    ret <cstd***GpuInitCall***>(_gpuInitFn);
];

rel cl GpuDrawPixel: [x i32, y i32, color i32] [
    if (_gpuDrawPixelFn == nullptr) [ ret -1; ];
    ret <cstd***GpuDrawPixelCall***>(_gpuDrawPixelFn, x, y, color);
];

rel cl GpuFlushRenderContext: [ctx ptr] [
    if (_gpuFlushFn == nullptr) [
        errs() << "DrvAPIInterCon: GpuFlushRenderContext non enregistré\n";
        ret -1;
    ];
    ret <cstd***GpuFlushCall***>(_gpuFlushFn, ctx);
];

rel cl GpuShutdown: [] [
    if (_gpuShutdownFn == nullptr) [ ret 0; ];
    ret <cstd***GpuShutdownCall***>(_gpuShutdownFn);
];

rel cl GpuSuspend: [] [
    if (_gpuSuspendFn == nullptr) [ ret 0; ];
    ret <cstd***GpuSuspendCall***>(_gpuSuspendFn);
];

rel cl GpuResume: [] [
    if (_gpuResumeFn == nullptr) [ ret 0; ];
    ret <cstd***GpuResumeCall***>(_gpuResumeFn);
];

rel cl GpuSetColorSpace: [space string] [
    if (_gpuSetColorSpaceFn == nullptr) [ ret -1; ];
    ret <cstd***GpuSetColorSpaceCall***>(_gpuSetColorSpaceFn, space);
];

rel cl GpuSetHDR: [enabled i32] [
    if (_gpuSetHDRFn == nullptr) [ ret -1; ];
    ret <cstd***GpuSetHDRCall***>(_gpuSetHDRFn, enabled);
];

rel cl GpuQueryHDRSupport: [] [
    if (_gpuQueryHDRFn == nullptr) [ ret 0; ];
    ret <cstd***GpuQueryHDRCall***>(_gpuQueryHDRFn);
];

rel cl GpuLoadICCProfileFromFile: [path string] [
    if (_gpuLoadICCFn == nullptr) [ ret -1; ];
    ret <cstd***GpuLoadICCCall***>(_gpuLoadICCFn, path);
];

rel cl GpuGetDisplayCapabilities: [] [
    if (_gpuGetCapsFn == nullptr) [ ret nullptr; ];
    ret <cstd***GpuGetCapsCall***>(_gpuGetCapsFn);
];

// -----------------------------------------------------------------
// 2. CPU – informations et charge
// -----------------------------------------------------------------
var _cpuGetVendorFn: <ptr> = nullptr;
var _cpuGetLoadFn:   <ptr> = nullptr;

rel cl RegisterCpuGetVendor: [fn ptr] [
    _cpuGetVendorFn = fn;
    ret 0;
];

rel cl RegisterCpuGetLoad: [fn ptr] [
    _cpuGetLoadFn = fn;
    ret 0;
];

rel cl CpuGetVendor: [] [
    if (_cpuGetVendorFn == nullptr) [ ret ""; ];
    ret <cstd***CpuGetVendorCall***>(_cpuGetVendorFn);
];

rel cl CpuGetLoad: [] [
    if (_cpuGetLoadFn == nullptr) [ ret -1; ];
    ret <cstd***CpuGetLoadCall***>(_cpuGetLoadFn);
];

// -----------------------------------------------------------------
// 3. Mémoire – allocation, libération, effacement
// -----------------------------------------------------------------
var _memAllocFn: <ptr> = nullptr;
var _memFreeFn:  <ptr> = nullptr;
var _memZeroFn:  <ptr> = nullptr;

rel cl RegisterMemAlloc: [fn ptr] [
    _memAllocFn = fn;
    ret 0;
];

rel cl RegisterMemFree: [fn ptr] [
    _memFreeFn = fn;
    ret 0;
];

rel cl RegisterMemZero: [fn ptr] [
    _memZeroFn = fn;
    ret 0;
];

rel cl MemAlloc: [size i32, zone i32, align i32] [
    if (_memAllocFn == nullptr) [ ret nullptr; ];
    ret <cstd***MemAllocCall***>(_memAllocFn, size, zone, align);
];

rel cl MemFree: [p ptr, zone i32] [
    if (_memFreeFn == nullptr) [ ret -1; ];
    ret <cstd***MemFreeCall***>(_memFreeFn, p, zone);
];

rel cl MemZero: [p ptr, size i32] [
    if (_memZeroFn == nullptr) [ ret -1; ];
    ret <cstd***MemZeroCall***>(_memZeroFn, p, size);
];

rel cl MemoryBarrier: [] [
    ret <cstd***MemBarrierCall***>();
];

// -----------------------------------------------------------------
// 4. Système de fichiers – ouverture, lecture, écriture, fermeture
// -----------------------------------------------------------------
var _fsOpenFn:         <ptr> = nullptr;
var _fsReadAllFn:      <ptr> = nullptr;
var _fsWriteFn:        <ptr> = nullptr;
var _fsCloseFn:        <ptr> = nullptr;
var _fsDeleteFn:       <ptr> = nullptr;
var _fsMkDirFn:        <ptr> = nullptr;
var _fsGetFreeSpaceFn: <ptr> = nullptr;

rel cl RegisterFSOpen: [fn ptr] [
    _fsOpenFn = fn;
    ret 0;
];

rel cl RegisterFSReadAll: [fn ptr] [
    _fsReadAllFn = fn;
    ret 0;
];

rel cl RegisterFSWrite: [fn ptr] [
    _fsWriteFn = fn;
    ret 0;
];

rel cl RegisterFSClose: [fn ptr] [
    _fsCloseFn = fn;
    ret 0;
];

rel cl RegisterFSDelete: [fn ptr] [
    _fsDeleteFn = fn;
    ret 0;
];

rel cl RegisterFSMkDir: [fn ptr] [
    _fsMkDirFn = fn;
    ret 0;
];

rel cl RegisterFSGetFreeSpace: [fn ptr] [
    _fsGetFreeSpaceFn = fn;
    ret 0;
];

rel cl FSOpen: [path string, mode i32] [
    if (_fsOpenFn == nullptr) [ ret nullptr; ];
    ret <cstd***FSOpenCall***>(_fsOpenFn, path, mode);
];

rel cl FSReadAll: [handle ptr] [
    if (_fsReadAllFn == nullptr) [ ret nullptr; ];
    ret <cstd***FSReadAllCall***>(_fsReadAllFn, handle);
];

rel cl FSWrite: [handle ptr, data ptr, size i32] [
    if (_fsWriteFn == nullptr) [ ret -1; ];
    ret <cstd***FSWriteCall***>(_fsWriteFn, handle, data, size);
];

rel cl FSClose: [handle ptr] [
    if (_fsCloseFn == nullptr) [ ret -1; ];
    ret <cstd***FSCloseCall***>(_fsCloseFn, handle);
];

rel cl FSDelete: [path string] [
    if (_fsDeleteFn == nullptr) [ ret -1; ];
    ret <cstd***FSDeleteCall***>(_fsDeleteFn, path);
];

rel cl FSMkDir: [path string, recursive bool] [
    if (_fsMkDirFn == nullptr) [ ret -1; ];
    ret <cstd***FSMkDirCall***>(_fsMkDirFn, path, recursive);
];

rel cl FSGetFreeSpace: [path string] [
    if (_fsGetFreeSpaceFn == nullptr) [ ret 0; ];
    ret <cstd***FSGetFreeSpaceCall***>(_fsGetFreeSpaceFn, path);
];

// -----------------------------------------------------------------
// 5. Réseau – WiFi, LTE, LoRa, eSIM
// -----------------------------------------------------------------
var _wifiGetSignalFn:  <ptr> = nullptr;
var _wifiConnectFn:    <ptr> = nullptr;
var _lteGetSignalFn:   <ptr> = nullptr;
var _lteConnectFn:     <ptr> = nullptr;
var _loraGetSignalFn:  <ptr> = nullptr;
var _loraConnectFn:    <ptr> = nullptr;
var _netDisconnectFn:  <ptr> = nullptr;
var _netGetSignalFn:   <ptr> = nullptr;
var _esimInitFn:       <ptr> = nullptr;

rel cl RegisterWifiGetSignal: [fn ptr] [ _wifiGetSignalFn = fn; ret 0; ];
rel cl RegisterWifiConnect:   [fn ptr] [ _wifiConnectFn   = fn; ret 0; ];
rel cl RegisterLteGetSignal:  [fn ptr] [ _lteGetSignalFn  = fn; ret 0; ];
rel cl RegisterLteConnect:    [fn ptr] [ _lteConnectFn    = fn; ret 0; ];
rel cl RegisterLoRaGetSignal: [fn ptr] [ _loraGetSignalFn = fn; ret 0; ];
rel cl RegisterLoRaConnect:   [fn ptr] [ _loraConnectFn   = fn; ret 0; ];
rel cl RegisterNetDisconnect: [fn ptr] [ _netDisconnectFn = fn; ret 0; ];
rel cl RegisterNetGetSignal:  [fn ptr] [ _netGetSignalFn  = fn; ret 0; ];
rel cl RegisterESimInit:      [fn ptr] [ _esimInitFn      = fn; ret 0; ];

rel cl WifiGetSignal:  [] [ if (_wifiGetSignalFn  == nullptr) [ ret 0;  ]; ret <cstd***WifiGetSignalCall***>(_wifiGetSignalFn);  ];
rel cl WifiConnect:    [apn string] [ if (_wifiConnectFn   == nullptr) [ ret -1; ]; ret <cstd***WifiConnectCall***>(_wifiConnectFn, apn);   ];
rel cl LteGetSignal:   [] [ if (_lteGetSignalFn   == nullptr) [ ret 0;  ]; ret <cstd***LteGetSignalCall***>(_lteGetSignalFn);   ];
rel cl LteConnect:     [apn string, iccid string] [ if (_lteConnectFn == nullptr) [ ret -1; ]; ret <cstd***LteConnectCall***>(_lteConnectFn, apn, iccid); ];
rel cl LoRaGetSignal:  [] [ if (_loraGetSignalFn  == nullptr) [ ret 0;  ]; ret <cstd***LoRaGetSignalCall***>(_loraGetSignalFn);  ];
rel cl LoRaConnect:    [apn string] [ if (_loraConnectFn   == nullptr) [ ret -1; ]; ret <cstd***LoRaConnectCall***>(_loraConnectFn, apn);   ];
rel cl NetDisconnect:  [net i32]    [ if (_netDisconnectFn  == nullptr) [ ret -1; ]; ret <cstd***NetDisconnectCall***>(_netDisconnectFn, net); ];
rel cl NetGetSignal:   [net i32]    [ if (_netGetSignalFn   == nullptr) [ ret 0;  ]; ret <cstd***NetGetSignalCall***>(_netGetSignalFn, net);   ];
rel cl ESimInit:       [iccid string] [ if (_esimInitFn     == nullptr) [ ret -1; ]; ret <cstd***ESimInitCall***>(_esimInitFn, iccid);         ];

