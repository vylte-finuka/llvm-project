];

// -----------------------------------------------------------------
// 10. Authentification – certificats, vérification signature
// -----------------------------------------------------------------
var _certLoadFn:   <ptr> = nullptr;
var _certVerifyFn: <ptr> = nullptr;
var _certPubKeyFn: <ptr> = nullptr;
var _authVerifyFn: <ptr> = nullptr;

rel cl RegisterCertLoadFromFile: [fn ptr] [ _certLoadFn   = fn; ret 0; ];
rel cl RegisterCertVerifyChain:  [fn ptr] [ _certVerifyFn = fn; ret 0; ];
rel cl RegisterCertGetPubKey:    [fn ptr] [ _certPubKeyFn = fn; ret 0; ];
rel cl RegisterAuthVerify:       [fn ptr] [ _authVerifyFn = fn; ret 0; ];

rel cl CertLoadFromFile: [path string] [
    if (_certLoadFn == nullptr) [ ret nullptr; ];
    ret <cstd***CertLoadCall***>(_certLoadFn, path);
];

rel cl CertVerifyChain: [cert ptr] [
    if (_certVerifyFn == nullptr) [ ret -1; ];
    ret <cstd***CertVerifyCall***>(_certVerifyFn, cert);
];

rel cl CertGetPubKey: [cert ptr] [
    if (_certPubKeyFn == nullptr) [ ret nullptr; ];
    ret <cstd***CertPubKeyCall***>(_certPubKeyFn, cert);
];

rel cl AuthVerify: [srid string, caKey ptr, level i32] [
    if (_authVerifyFn == nullptr) [ ret -1; ];
    ret <cstd***AuthVerifyCall***>(_authVerifyFn, srid, caKey, level);
];

// -----------------------------------------------------------------
// 11. Instance – chargement, démarrage, déchargement
// -----------------------------------------------------------------
var _instanceStartFn:  <ptr> = nullptr;
var _instanceUnloadFn: <ptr> = nullptr;
var _callbackInvokeFn: <ptr> = nullptr;

rel cl RegisterInstanceStart:    [fn ptr] [ _instanceStartFn  = fn; ret 0; ];
rel cl RegisterInstanceUnload:   [fn ptr] [ _instanceUnloadFn = fn; ret 0; ];
rel cl RegisterCallbackInvoke:   [fn ptr] [ _callbackInvokeFn = fn; ret 0; ];

rel cl InstanceStart: [entryPtr ptr] [
    if (_instanceStartFn == nullptr) [ ret -1; ];
    ret <cstd***InstanceStartCall***>(_instanceStartFn, entryPtr);
];

rel cl InstanceUnload: [handle ptr] [
    if (_instanceUnloadFn == nullptr) [ ret -1; ];
    ret <cstd***InstanceUnloadCall***>(_instanceUnloadFn, handle);
];

rel cl CallbackInvoke: [cb ptr] [
    if (_callbackInvokeFn == nullptr) [ ret -1; ];
    ret <cstd***CallbackInvokeCall***>(_callbackInvokeFn, cb);
];

// -----------------------------------------------------------------
// 12. UI – texte, couleurs, mise en page
// -----------------------------------------------------------------
var _textRenderFn:      <ptr> = nullptr;
var _textMeasureWFn:    <ptr> = nullptr;
var _textMeasureHFn:    <ptr> = nullptr;
var _uiSetBgColorFn:    <ptr> = nullptr;
var _uiSetTextColorFn:  <ptr> = nullptr;
var _uiSetMarginFn:     <ptr> = nullptr;
var _uiSetPaddingFn:    <ptr> = nullptr;
var _fontLoadFn:        <ptr> = nullptr;
var _fontGetDefaultFn:  <ptr> = nullptr;
var _fontGetHeightFn:   <ptr> = nullptr;

rel cl RegisterTextRender:     [fn ptr] [ _textRenderFn     = fn; ret 0; ];
rel cl RegisterTextMeasureW:   [fn ptr] [ _textMeasureWFn   = fn; ret 0; ];
rel cl RegisterTextMeasureH:   [fn ptr] [ _textMeasureHFn   = fn; ret 0; ];
rel cl RegisterUISetBgColor:   [fn ptr] [ _uiSetBgColorFn   = fn; ret 0; ];
rel cl RegisterUISetTextColor: [fn ptr] [ _uiSetTextColorFn = fn; ret 0; ];
rel cl RegisterUISetMargin:    [fn ptr] [ _uiSetMarginFn    = fn; ret 0; ];
rel cl RegisterUISetPadding:   [fn ptr] [ _uiSetPaddingFn   = fn; ret 0; ];
rel cl RegisterFontLoad:       [fn ptr] [ _fontLoadFn       = fn; ret 0; ];
rel cl RegisterFontGetDefault: [fn ptr] [ _fontGetDefaultFn = fn; ret 0; ];
rel cl RegisterFontGetHeight:  [fn ptr] [ _fontGetHeightFn  = fn; ret 0; ];

rel cl TextRender: [text string, x i32, y i32, font ptr, color i32] [
    if (_textRenderFn == nullptr) [ ret -1; ];
    ret <cstd***TextRenderCall***>(_textRenderFn, text, x, y, font, color);
];

rel cl TextMeasureWidth: [text string, font ptr] [
