];

rel cl ProcessGetUID: [] [
    if (_procGetUIDFn == nullptr) [ ret -1; ];
    ret <cstd***ProcGetUIDCall***>(_procGetUIDFn);
];

rel cl ProcessGetThreadCount: [] [
