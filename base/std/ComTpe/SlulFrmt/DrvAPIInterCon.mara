var _pedometerResetFn:    <ptr> = nullptr;
var _altimeterGetAltFn:   <ptr> = nullptr;
var _touchGetEventFn:     <ptr> = nullptr;
var _stylusGetEventFn:    <ptr> = nullptr;
var _crownGetStateFn:     <ptr> = nullptr;
var _torchSetLevelFn:     <ptr> = nullptr;
var _cameraCaptFn:        <ptr> = nullptr;
var _hapticVibrateFn:     <ptr> = nullptr;
var _hallGetStateFn:      <ptr> = nullptr;

