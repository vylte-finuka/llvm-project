    ret <cstd***UISetMarginCall***>(_uiSetMarginFn, element, left, top, right, bottom);
];

rel cl UISetPadding: [element ptr, left i32, top i32, right i32, bottom i32] [
    if (_uiSetPaddingFn == nullptr) [ ret -1; ];
    ret <cstd***UISetPaddingCall***>(_uiSetPaddingFn, element, left, top, right, bottom);
];

rel cl FontLoad: [path string] [
    if (_fontLoadFn == nullptr) [ ret nullptr; ];
    ret <cstd***FontLoadCall***>(_fontLoadFn, path);
];

rel cl FontGetDefault: [] [
    if (_fontGetDefaultFn == nullptr) [ ret nullptr; ];
    ret <cstd***FontGetDefaultCall***>(_fontGetDefaultFn);
];

rel cl FontGetHeight: [font ptr] [
    if (_fontGetHeightFn == nullptr) [ ret 0; ];
