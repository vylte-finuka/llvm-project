rel cl RegisterAltimeterGetAlt:   [fn ptr] [ _altimeterGetAltFn   = fn; ret 0; ];
rel cl RegisterTouchGetEvent:     [fn ptr] [ _touchGetEventFn     = fn; ret 0; ];
