#include <cstddef>

//___
//___ Load a font from a file.
//___
rel op LoadFont: <path String> [
    // Placeholder: actual implementation would interface with font system (e.g., FreeType)
    let fontPtr ptr = nullptr; // To be implemented
    if (fontPtr == nullptr) then [
        log: "Failed to load font from: " + path;
    ] else [
        log: "Successfully loaded font from: " + path;
    ];
    ret fontPtr;
];

//___
//___ Get the default system font.
//___
rel op GetDefaultFont: [] [
    let fontPtr ptr = nullptr; // To be implemented
    log: "Retrieved default system font.";
    ret fontPtr;
];

//___
