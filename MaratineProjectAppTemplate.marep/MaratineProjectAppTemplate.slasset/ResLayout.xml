<?xml version="1.0" encoding="UTF-8"?>
<!-- ResLayout.xml – Déclaration de l'icône du lanceur pour le bundle Maratine -->
<Layout version="1.0" xmlns="http://vyft.com/schema/reslayout">
    <!-- Icône du lanceur -->
    <Icon src="exemple icon app.png" />
    <!-- Déclaration des orientations supportées : vertical, horizontal, hybride, 4‑sens -->
    <SupportedOrientations>
        <Orientation>vertical</Orientation>
        <Orientation>horizontal</Orientation>
        <Orientation>hybrid</Orientation>
        <Orientation>four-way</Orientation>
    </SupportedOrientations>
</Layout>
