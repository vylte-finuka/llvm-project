; Test PHI node with boolean vector in a simple loop
define <4 x i32> @test_phi_simple_loop(<4 x i32> %a, <4 x i32> %b, <4 x i32> %c, i32 %n) {
; CHECK-LABEL: test_phi_simple_loop:
; CHECK:       // %bb.0: // %entry
; CHECK-NEXT:    cmgt v3.4s, v1.4s, v2.4s
; CHECK-NEXT:    cmgt v1.4s, v1.4s, v0.4s
; CHECK-NEXT:    mov w8, wzr
; CHECK-NEXT:  .LBB17_1: // %loop
; CHECK-NEXT:    // =>This Inner Loop Header: Depth=1
; CHECK-NEXT:    mov v4.16b, v1.16b
; CHECK-NEXT:    and v1.16b, v1.16b, v3.16b
; CHECK-NEXT:    add w8, w8, #1
; CHECK-NEXT:    cmp w8, w0
; CHECK-NEXT:    b.lt .LBB17_1
; CHECK-NEXT:  // %bb.2: // %exit
; CHECK-NEXT:    cmlt v1.4s, v4.4s, #0
; CHECK-NEXT:    bif v0.16b, v2.16b, v1.16b
; CHECK-NEXT:    ret
;
; DISABLE-LABEL: test_phi_simple_loop:
; DISABLE:       // %bb.0: // %entry
; DISABLE-NEXT:    cmgt v3.4s, v1.4s, v2.4s
; DISABLE-NEXT:    cmgt v4.4s, v1.4s, v0.4s
; DISABLE-NEXT:    mov w8, wzr
; DISABLE-NEXT:    xtn v1.4h, v3.4s
; DISABLE-NEXT:    xtn v3.4h, v4.4s
; DISABLE-NEXT:  .LBB17_1: // %loop
; DISABLE-NEXT:    // =>This Inner Loop Header: Depth=1
; DISABLE-NEXT:    fmov d4, d3
; DISABLE-NEXT:    and v3.8b, v3.8b, v1.8b
; DISABLE-NEXT:    add w8, w8, #1
; DISABLE-NEXT:    cmp w8, w0
; DISABLE-NEXT:    b.lt .LBB17_1
; DISABLE-NEXT:  // %bb.2: // %exit
; DISABLE-NEXT:    ushll v1.4s, v4.4h, #0
; DISABLE-NEXT:    shl v1.4s, v1.4s, #31
; DISABLE-NEXT:    cmlt v1.4s, v1.4s, #0
; DISABLE-NEXT:    bif v0.16b, v2.16b, v1.16b
; DISABLE-NEXT:    ret
entry:
  %cmp.init = icmp slt <4 x i32> %a, %b
  br label %loop

loop:
  %i = phi i32 [ 0, %entry ], [ %i.next, %loop ]
  %mask = phi <4 x i1> [ %cmp.init, %entry ], [ %mask.next, %loop ]
  %cmp.loop = icmp sgt <4 x i32> %b, %c
  %mask.next = and <4 x i1> %mask, %cmp.loop
  %i.next = add i32 %i, 1
  %cond = icmp slt i32 %i.next, %n
  br i1 %cond, label %loop, label %exit

exit:
  %sel = select <4 x i1> %mask, <4 x i32> %a, <4 x i32> %c
  ret <4 x i32> %sel
}

; Test PHI node with multiple predecessors
define <4 x i32> @test_phi_diamond(<4 x i32> %a, <4 x i32> %b, <4 x i32> %c, <4 x i32> %d, i1 %cond) {
; CHECK-LABEL: test_phi_diamond:
; CHECK:       // %bb.0: // %entry
; CHECK-NEXT:    tbz w0, #0, .LBB18_2
; CHECK-NEXT:  // %bb.1: // %then
; CHECK-NEXT:    cmgt v1.4s, v1.4s, v0.4s
; CHECK-NEXT:    cmgt v3.4s, v2.4s, v3.4s
; CHECK-NEXT:    and v1.16b, v1.16b, v3.16b
; CHECK-NEXT:    cmlt v1.4s, v1.4s, #0
; CHECK-NEXT:    bif v0.16b, v2.16b, v1.16b
; CHECK-NEXT:    ret
; CHECK-NEXT:  .LBB18_2: // %else
; CHECK-NEXT:    cmge v4.4s, v2.4s, v0.4s
; CHECK-NEXT:    cmge v1.4s, v1.4s, v3.4s
; CHECK-NEXT:    orr v1.16b, v4.16b, v1.16b
; CHECK-NEXT:    cmlt v1.4s, v1.4s, #0
; CHECK-NEXT:    bif v0.16b, v2.16b, v1.16b
; CHECK-NEXT:    ret
;
; DISABLE-LABEL: test_phi_diamond:
; DISABLE:       // %bb.0: // %entry
; DISABLE-NEXT:    cmge v4.4s, v1.4s, v3.4s
; DISABLE-NEXT:    cmge v5.4s, v2.4s, v0.4s
; DISABLE-NEXT:    tst w0, #0x1
; DISABLE-NEXT:    cmgt v1.4s, v1.4s, v0.4s
; DISABLE-NEXT:    cmgt v3.4s, v2.4s, v3.4s
; DISABLE-NEXT:    orr v4.16b, v5.16b, v4.16b
; DISABLE-NEXT:    and v1.16b, v1.16b, v3.16b
; DISABLE-NEXT:    xtn v3.4h, v4.4s
; DISABLE-NEXT:    xtn v1.4h, v1.4s
; DISABLE-NEXT:    fcsel d1, d3, d1, eq
; DISABLE-NEXT:    ushll v1.4s, v1.4h, #0
; DISABLE-NEXT:    shl v1.4s, v1.4s, #31
; DISABLE-NEXT:    cmlt v1.4s, v1.4s, #0
; DISABLE-NEXT:    bif v0.16b, v2.16b, v1.16b
; DISABLE-NEXT:    ret
entry:
  br i1 %cond, label %then, label %else

then:
  %cmp.then = icmp slt <4 x i32> %a, %b
  %cmp.then2 = icmp sgt <4 x i32> %c, %d
  %and.then = and <4 x i1> %cmp.then, %cmp.then2
  br label %merge

else:
  %cmp.else = icmp sle <4 x i32> %a, %c
  %cmp.else2 = icmp sge <4 x i32> %b, %d
  %or.else = or <4 x i1> %cmp.else, %cmp.else2
  br label %merge

merge:
  %mask = phi <4 x i1> [ %and.then, %then ], [ %or.else, %else ]
  %sel = select <4 x i1> %mask, <4 x i32> %a, <4 x i32> %c
  ret <4 x i32> %sel
}

; Test diamond PHI with comparison masks created in if/else blocks
; and one mask selected at exit (no bitwise ops on masks)
declare void @barrier()
define <4 x float> @test_phi_diamond_mask_select(<4 x float> %a, <4 x float> %b, <4 x float> %c, <4 x float> %d, i1 %cond) {
; CHECK-LABEL: test_phi_diamond_mask_select:
; CHECK:       // %bb.0: // %entry
; CHECK-NEXT:    sub sp, sp, #64
; CHECK-NEXT:    str x30, [sp, #48] // 8-byte Spill
; CHECK-NEXT:    .cfi_def_cfa_offset 64
; CHECK-NEXT:    .cfi_offset w30, -16
; CHECK-NEXT:    stp q0, q2, [sp, #16] // 32-byte Folded Spill
; CHECK-NEXT:    tbz w0, #0, .LBB19_2
; CHECK-NEXT:  // %bb.1: // %if.then
; CHECK-NEXT:    str q1, [sp] // 16-byte Spill
; CHECK-NEXT:    bl barrier
; CHECK-NEXT:    ldp q0, q2, [sp] // 32-byte Folded Reload
; CHECK-NEXT:    ldr q1, [sp, #32] // 16-byte Reload
; CHECK-NEXT:    fcmgt v0.4s, v0.4s, v2.4s
; CHECK-NEXT:    cmlt v0.4s, v0.4s, #0
; CHECK-NEXT:    ldr x30, [sp, #48] // 8-byte Reload
; CHECK-NEXT:    bsl v0.16b, v2.16b, v1.16b
; CHECK-NEXT:    add sp, sp, #64
; CHECK-NEXT:    ret
; CHECK-NEXT:  .LBB19_2: // %if.else
; CHECK-NEXT:    str q3, [sp] // 16-byte Spill
; CHECK-NEXT:    bl barrier
; CHECK-NEXT:    ldp q2, q1, [sp, #16] // 32-byte Folded Reload
; CHECK-NEXT:    ldr q0, [sp] // 16-byte Reload
; CHECK-NEXT:    fcmgt v0.4s, v0.4s, v1.4s
; CHECK-NEXT:    cmlt v0.4s, v0.4s, #0
; CHECK-NEXT:    ldr x30, [sp, #48] // 8-byte Reload
; CHECK-NEXT:    bsl v0.16b, v2.16b, v1.16b
; CHECK-NEXT:    add sp, sp, #64
; CHECK-NEXT:    ret
;
; DISABLE-LABEL: test_phi_diamond_mask_select:
; DISABLE:       // %bb.0: // %entry
; DISABLE-NEXT:    sub sp, sp, #64
; DISABLE-NEXT:    str x30, [sp, #48] // 8-byte Spill
; DISABLE-NEXT:    .cfi_def_cfa_offset 64
; DISABLE-NEXT:    .cfi_offset w30, -16
; DISABLE-NEXT:    stp q0, q2, [sp, #16] // 32-byte Folded Spill
; DISABLE-NEXT:    tbz w0, #0, .LBB19_2
; DISABLE-NEXT:  // %bb.1: // %if.then
; DISABLE-NEXT:    str q1, [sp] // 16-byte Spill
; DISABLE-NEXT:    bl barrier
; DISABLE-NEXT:    ldp q0, q2, [sp] // 32-byte Folded Reload
; DISABLE-NEXT:    ldr q1, [sp, #32] // 16-byte Reload
; DISABLE-NEXT:    fcmgt v0.4s, v0.4s, v2.4s
; DISABLE-NEXT:    b .LBB19_3
; DISABLE-NEXT:  .LBB19_2: // %if.else
; DISABLE-NEXT:    str q3, [sp] // 16-byte Spill
; DISABLE-NEXT:    bl barrier
; DISABLE-NEXT:    ldp q2, q1, [sp, #16] // 32-byte Folded Reload
; DISABLE-NEXT:    ldr q0, [sp] // 16-byte Reload
; DISABLE-NEXT:    fcmgt v0.4s, v0.4s, v1.4s
; DISABLE-NEXT:  .LBB19_3: // %exit
; DISABLE-NEXT:    xtn v0.4h, v0.4s
; DISABLE-NEXT:    ushll v0.4s, v0.4h, #0
; DISABLE-NEXT:    ldr x30, [sp, #48] // 8-byte Reload
; DISABLE-NEXT:    shl v0.4s, v0.4s, #31
; DISABLE-NEXT:    cmlt v0.4s, v0.4s, #0
; DISABLE-NEXT:    bsl v0.16b, v2.16b, v1.16b
; DISABLE-NEXT:    add sp, sp, #64
; DISABLE-NEXT:    ret
entry:
  br i1 %cond, label %if.then, label %if.else, !unpredictable !0

if.then:
  call void @barrier() #0
  %mask.then = fcmp olt <4 x float> %a, %b
  br label %exit

if.else:
  call void @barrier() #0
  %mask.else = fcmp olt <4 x float> %c, %d
  br label %exit

exit:
  %mask = phi <4 x i1> [ %mask.then, %if.then ], [ %mask.else, %if.else ]
  %sel = select <4 x i1> %mask, <4 x float> %a, <4 x float> %c
  ret <4 x float> %sel
}

