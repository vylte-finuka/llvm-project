; CHECK-LABEL: test_fcmp_v4_and:
; CHECK:       // %bb.0: // %entry
; CHECK-NEXT:    fcmge v3.4s, v3.4s, v2.4s
; CHECK-NEXT:    fcmge v1.4s, v1.4s, v0.4s
; CHECK-NEXT:    and v1.16b, v1.16b, v3.16b
; CHECK-NEXT:    bif v0.16b, v2.16b, v1.16b
; CHECK-NEXT:    ret
;
; DISABLE-LABEL: test_fcmp_v4_and:
