; DISABLE-NEXT:    fcmge v3.4s, v3.4s, v2.4s
; DISABLE-NEXT:    fcmge v1.4s, v1.4s, v0.4s
; DISABLE-NEXT:    and v1.16b, v1.16b, v3.16b
; DISABLE-NEXT:    bif v0.16b, v2.16b, v1.16b
; DISABLE-NEXT:    ret
entry:
  %cmp1 = fcmp ole <4 x float> %a, %b
  %cmp2 = fcmp ole <4 x float> %c, %d
  %and = and <4 x i1> %cmp1, %cmp2
  %sel = select <4 x i1> %and, <4 x float> %a, <4 x float> %c
  ret <4 x float> %sel
}

