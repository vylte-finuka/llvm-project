; DISABLE-SAME: <4 x float> [[A:%.*]], <4 x float> [[B:%.*]], <4 x float> [[X:%.*]], i1 [[C:%.*]]) {
; DISABLE-NEXT:  [[ENTRY:.*:]]
; DISABLE-NEXT:    [[CMP1:%.*]] = fcmp uno <4 x float> [[A]], [[B]]
; DISABLE-NEXT:    br i1 [[C]], label %[[L:.*]], label %[[R:.*]]
; DISABLE:       [[L]]:
; DISABLE-NEXT:    [[CMP2:%.*]] = fcmp ord <4 x float> [[A]], [[B]]
; DISABLE-NEXT:    br label %[[J:.*]]
; DISABLE:       [[R]]:
; DISABLE-NEXT:    br label %[[J]]
