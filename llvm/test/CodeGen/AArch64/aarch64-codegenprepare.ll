; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    [[CMP1:%.*]] = fcmp uno <4 x float> [[A]], [[B]]
; CHECK-NEXT:    [[CMP1_WIDE:%.*]] = sext <4 x i1> [[CMP1]] to <4 x i32>
; CHECK-NEXT:    br i1 [[C]], label %[[L:.*]], label %[[R:.*]]
; CHECK:       [[L]]:
; CHECK-NEXT:    [[CMP2:%.*]] = fcmp ord <4 x float> [[A]], [[B]]
