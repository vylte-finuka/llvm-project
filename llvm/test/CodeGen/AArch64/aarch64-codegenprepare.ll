;-----------------------------------------------------------------------
; Length-changing shufflevector across a phi
;-----------------------------------------------------------------------

;; A shufflevector that produces a different element count breaks chain
;; connectivity at the NumElts boundary; each NumElts gets its own chain.
;; The pass must not pull values of different element counts into one
;; rewrite.
define <4 x i32> @length_changing_shuffle(<8 x float> %a, <8 x float> %b,
; CHECK-LABEL: define <4 x i32> @length_changing_shuffle(
; CHECK-SAME: <8 x float> [[A:%.*]], <8 x float> [[B:%.*]], <4 x i32> [[X:%.*]], <4 x i32> [[Y:%.*]], i1 [[C:%.*]]) {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    [[CMP8:%.*]] = fcmp ole <8 x float> [[A]], [[B]]
; CHECK-NEXT:    br i1 [[C]], label %[[L:.*]], label %[[R:.*]]
; CHECK:       [[L]]:
; CHECK-NEXT:    [[SHUF:%.*]] = shufflevector <8 x i1> [[CMP8]], <8 x i1> poison, <4 x i32> <i32 0, i32 1, i32 2, i32 3>
; CHECK-NEXT:    br label %[[J:.*]]
; CHECK:       [[R]]:
; CHECK-NEXT:    br label %[[J]]
; CHECK:       [[J]]:
; CHECK-NEXT:    [[M:%.*]] = phi <4 x i1> [ [[SHUF]], %[[L]] ], [ zeroinitializer, %[[R]] ]
; CHECK-NEXT:    [[SEL:%.*]] = select <4 x i1> [[M]], <4 x i32> [[X]], <4 x i32> [[Y]]
; CHECK-NEXT:    ret <4 x i32> [[SEL]]
