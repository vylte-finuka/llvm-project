;; IR-level tests for AArch64CodeGenPrepare's widening of cross-block
;; <N x i1> chains. Each test exercises one rewriting facet so failures
;; pinpoint a specific behavior.

;-----------------------------------------------------------------------
; Trigger gating
;-----------------------------------------------------------------------

;; A chain that has no cross-block use is left alone.
define <4 x i32> @no_crossblock(<4 x i32> %a, <4 x i32> %b, <4 x i32> %c, <4 x i32> %d) {
; CHECK-LABEL: define <4 x i32> @no_crossblock(
; CHECK-SAME: <4 x i32> [[A:%.*]], <4 x i32> [[B:%.*]], <4 x i32> [[C:%.*]], <4 x i32> [[D:%.*]]) {
; CHECK-NEXT:    [[CMP1:%.*]] = icmp eq <4 x i32> [[A]], [[B]]
; CHECK-NEXT:    [[CMP2:%.*]] = icmp eq <4 x i32> [[C]], [[D]]
; CHECK-NEXT:    [[AND:%.*]] = and <4 x i1> [[CMP1]], [[CMP2]]
; CHECK-NEXT:    [[SEL:%.*]] = select <4 x i1> [[AND]], <4 x i32> [[A]], <4 x i32> [[B]]
; CHECK-NEXT:    ret <4 x i32> [[SEL]]
;
; DISABLE-LABEL: define <4 x i32> @no_crossblock(
; DISABLE-SAME: <4 x i32> [[A:%.*]], <4 x i32> [[B:%.*]], <4 x i32> [[C:%.*]], <4 x i32> [[D:%.*]]) {
; DISABLE-NEXT:    [[CMP1:%.*]] = icmp eq <4 x i32> [[A]], [[B]]
; DISABLE-NEXT:    [[CMP2:%.*]] = icmp eq <4 x i32> [[C]], [[D]]
; DISABLE-NEXT:    [[AND:%.*]] = and <4 x i1> [[CMP1]], [[CMP2]]
; DISABLE-NEXT:    [[SEL:%.*]] = select <4 x i1> [[AND]], <4 x i32> [[A]], <4 x i32> [[B]]
; DISABLE-NEXT:    ret <4 x i32> [[SEL]]
;
  %cmp1 = icmp eq <4 x i32> %a, %b
  %cmp2 = icmp eq <4 x i32> %c, %d
  %and = and <4 x i1> %cmp1, %cmp2
  %sel = select <4 x i1> %and, <4 x i32> %a, <4 x i32> %b
  ret <4 x i32> %sel
}

;; A chain with cross-block uses but no joining op (just a cmp + extracts in
;; another block) is degenerate -- widening + re-narrowing buys nothing.
;; Pass must skip.
define void @bare_cmp_crossblock_extract(<2 x i64> %v, ptr %dst) {
; CHECK-LABEL: define void @bare_cmp_crossblock_extract(
; CHECK-SAME: <2 x i64> [[V:%.*]], ptr [[DST:%.*]]) {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    [[VEC_CMP:%.*]] = icmp ult <2 x i64> [[V]], splat (i64 15)
; CHECK-NEXT:    [[C0:%.*]] = extractelement <2 x i1> [[VEC_CMP]], i64 0
; CHECK-NEXT:    br i1 [[C0]], label %[[STORE:.*]], label %[[CONT:.*]]
; CHECK:       [[STORE]]:
; CHECK-NEXT:    [[C1:%.*]] = extractelement <2 x i1> [[VEC_CMP]], i64 1
; CHECK-NEXT:    store i32 1, ptr [[DST]], align 4
; CHECK-NEXT:    br label %[[CONT]]
; CHECK:       [[CONT]]:
; CHECK-NEXT:    ret void
;
; DISABLE-LABEL: define void @bare_cmp_crossblock_extract(
; DISABLE-SAME: <2 x i64> [[V:%.*]], ptr [[DST:%.*]]) {
; DISABLE-NEXT:  [[ENTRY:.*:]]
; DISABLE-NEXT:    [[VEC_CMP:%.*]] = icmp ult <2 x i64> [[V]], splat (i64 15)
; DISABLE-NEXT:    [[C0:%.*]] = extractelement <2 x i1> [[VEC_CMP]], i64 0
; DISABLE-NEXT:    br i1 [[C0]], label %[[STORE:.*]], label %[[CONT:.*]]
; DISABLE:       [[STORE]]:
; DISABLE-NEXT:    [[C1:%.*]] = extractelement <2 x i1> [[VEC_CMP]], i64 1
; DISABLE-NEXT:    store i32 1, ptr [[DST]], align 4
; DISABLE-NEXT:    br label %[[CONT]]
; DISABLE:       [[CONT]]:
; DISABLE-NEXT:    ret void
;
entry:
  %vec.cmp = icmp ult <2 x i64> %v, <i64 15, i64 15>
  %c0 = extractelement <2 x i1> %vec.cmp, i64 0
  br i1 %c0, label %store, label %cont
store:
  %c1 = extractelement <2 x i1> %vec.cmp, i64 1
  store i32 1, ptr %dst, align 4
  br label %cont
cont:
  ret void
}

