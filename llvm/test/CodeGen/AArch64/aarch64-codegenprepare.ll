;; A loaded <4 x i1> feeds two ANDs in non-dominating successor blocks
;; that join at a PHI. The widened sext of the load must be placed at the
;; load's def site (entry) so it dominates both consumers.
define <4 x i32> @nonchain_op_dominance(ptr %p, <4 x i32> %a, <4 x i32> %b,
