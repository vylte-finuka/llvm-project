  ret <4 x i32> %sel
}

;-----------------------------------------------------------------------
; Constant <N x i1> operands inside the chain
;-----------------------------------------------------------------------

;; A constant <4 x i1> in the and/or chain gets a sext to the wide type.
define <4 x i32> @constant_in_chain(<4 x i32> %a, <4 x i32> %b, <4 x i32> %x, i1 %c) {
; CHECK-LABEL: define <4 x i32> @constant_in_chain(
