; DISABLE-NEXT:    [[SEL:%.*]] = select <4 x i1> [[M]], <4 x i32> [[X]], <4 x i32> [[Y]]
; DISABLE-NEXT:    ret <4 x i32> [[SEL]]
;
  <4 x i32> %x, <4 x i32> %y, i1 %c) {
entry:
  %x_i1 = load <4 x i1>, ptr %p, align 1
  %cmp = icmp eq <4 x i32> %a, %b
  br i1 %c, label %l, label %r
l:
  %andL = and <4 x i1> %cmp, %x_i1
