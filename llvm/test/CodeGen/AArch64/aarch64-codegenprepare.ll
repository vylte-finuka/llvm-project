; CHECK-NEXT:    [[CMP:%.*]] = icmp eq <4 x i32> [[A]], [[B]]
; CHECK-NEXT:    [[CMP_WIDE:%.*]] = sext <4 x i1> [[CMP]] to <4 x i32>
; CHECK-NEXT:    br i1 [[C]], label %[[L:.*]], label %[[R:.*]]
; CHECK:       [[L]]:
; CHECK-NEXT:    [[ANDL_WIDE:%.*]] = and <4 x i32> [[CMP_WIDE]], [[TMP0]]
; CHECK-NEXT:    br label %[[J:.*]]
; CHECK:       [[R]]:
; CHECK-NEXT:    [[ANDR_WIDE:%.*]] = and <4 x i32> [[CMP_WIDE]], [[TMP0]]
; CHECK-NEXT:    br label %[[J]]
; CHECK:       [[J]]:
; CHECK-NEXT:    [[M_WIDE:%.*]] = phi <4 x i32> [ [[ANDL_WIDE]], %[[L]] ], [ [[ANDR_WIDE]], %[[R]] ]
; CHECK-NEXT:    [[M_NARROW:%.*]] = icmp slt <4 x i32> [[M_WIDE]], zeroinitializer
; CHECK-NEXT:    [[SEL:%.*]] = select <4 x i1> [[M_NARROW]], <4 x i32> [[X]], <4 x i32> [[Y]]
; CHECK-NEXT:    ret <4 x i32> [[SEL]]
;
