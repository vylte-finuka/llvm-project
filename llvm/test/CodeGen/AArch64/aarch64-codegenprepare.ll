;-----------------------------------------------------------------------
; Cross-block PHI chain (the canonical motivating case)
;-----------------------------------------------------------------------

;; A loop-carried <4 x i1> PHI accumulating an AND of compare results.
;; The chain (PHI + compares + AND) is rewritten on <4 x i32>.
define <4 x i32> @phi_loop(<4 x i32> %a, <4 x i32> %b, <4 x i32> %c, i32 %n) {
; CHECK-LABEL: define <4 x i32> @phi_loop(
; CHECK-SAME: <4 x i32> [[A:%.*]], <4 x i32> [[B:%.*]], <4 x i32> [[C:%.*]], i32 [[N:%.*]]) {
; CHECK-NEXT:  [[ENTRY:.*]]:
; CHECK-NEXT:    [[CMP_INIT:%.*]] = icmp slt <4 x i32> [[A]], [[B]]
; CHECK-NEXT:    [[CMP_INIT_WIDE:%.*]] = sext <4 x i1> [[CMP_INIT]] to <4 x i32>
; CHECK-NEXT:    br label %[[LOOP:.*]]
; CHECK:       [[LOOP]]:
; CHECK-NEXT:    [[I:%.*]] = phi i32 [ 0, %[[ENTRY]] ], [ [[I_NEXT:%.*]], %[[LOOP]] ]
; CHECK-NEXT:    [[MASK_WIDE:%.*]] = phi <4 x i32> [ [[CMP_INIT_WIDE]], %[[ENTRY]] ], [ [[MASK_NEXT_WIDE:%.*]], %[[LOOP]] ]
; CHECK-NEXT:    [[MASK_NARROW:%.*]] = icmp slt <4 x i32> [[MASK_WIDE]], zeroinitializer
; CHECK-NEXT:    [[CMP_LOOP:%.*]] = icmp sgt <4 x i32> [[B]], [[C]]
; CHECK-NEXT:    [[CMP_LOOP_WIDE:%.*]] = sext <4 x i1> [[CMP_LOOP]] to <4 x i32>
; CHECK-NEXT:    [[MASK_NEXT_WIDE]] = and <4 x i32> [[MASK_WIDE]], [[CMP_LOOP_WIDE]]
; CHECK-NEXT:    [[I_NEXT]] = add i32 [[I]], 1
; CHECK-NEXT:    [[COND:%.*]] = icmp slt i32 [[I_NEXT]], [[N]]
; CHECK-NEXT:    br i1 [[COND]], label %[[LOOP]], label %[[EXIT:.*]]
; CHECK:       [[EXIT]]:
; CHECK-NEXT:    [[SEL:%.*]] = select <4 x i1> [[MASK_NARROW]], <4 x i32> [[A]], <4 x i32> [[C]]
; CHECK-NEXT:    ret <4 x i32> [[SEL]]
;
; DISABLE-LABEL: define <4 x i32> @phi_loop(
; DISABLE-SAME: <4 x i32> [[A:%.*]], <4 x i32> [[B:%.*]], <4 x i32> [[C:%.*]], i32 [[N:%.*]]) {
; DISABLE-NEXT:  [[ENTRY:.*]]:
; DISABLE-NEXT:    [[CMP_INIT:%.*]] = icmp slt <4 x i32> [[A]], [[B]]
; DISABLE-NEXT:    br label %[[LOOP:.*]]
; DISABLE:       [[LOOP]]:
; DISABLE-NEXT:    [[I:%.*]] = phi i32 [ 0, %[[ENTRY]] ], [ [[I_NEXT:%.*]], %[[LOOP]] ]
; DISABLE-NEXT:    [[MASK:%.*]] = phi <4 x i1> [ [[CMP_INIT]], %[[ENTRY]] ], [ [[MASK_NEXT:%.*]], %[[LOOP]] ]
; DISABLE-NEXT:    [[CMP_LOOP:%.*]] = icmp sgt <4 x i32> [[B]], [[C]]
; DISABLE-NEXT:    [[MASK_NEXT]] = and <4 x i1> [[MASK]], [[CMP_LOOP]]
; DISABLE-NEXT:    [[I_NEXT]] = add i32 [[I]], 1
; DISABLE-NEXT:    [[COND:%.*]] = icmp slt i32 [[I_NEXT]], [[N]]
; DISABLE-NEXT:    br i1 [[COND]], label %[[LOOP]], label %[[EXIT:.*]]
; DISABLE:       [[EXIT]]:
; DISABLE-NEXT:    [[SEL:%.*]] = select <4 x i1> [[MASK]], <4 x i32> [[A]], <4 x i32> [[C]]
; DISABLE-NEXT:    ret <4 x i32> [[SEL]]
;
entry:
  %cmp.init = icmp slt <4 x i32> %a, %b
  br label %loop
loop:
  %i = phi i32 [ 0, %entry ], [ %i.next, %loop ]
  %mask = phi <4 x i1> [ %cmp.init, %entry ], [ %mask.next, %loop ]
  %cmp.loop = icmp sgt <4 x i32> %b, %c
  %mask.next = and <4 x i1> %mask, %cmp.loop
  %i.next = add i32 %i, 1
  %cond = icmp slt i32 %i.next, %n
  br i1 %cond, label %loop, label %exit
exit:
  %sel = select <4 x i1> %mask, <4 x i32> %a, <4 x i32> %c
  ret <4 x i32> %sel
}

;-----------------------------------------------------------------------
; Mixed-source-width chain: pick wider rule
;-----------------------------------------------------------------------

;; cmp_v4i32 + cmp_v4i16 join at an `and` whose result is consumed in
;; another block. The pass must pick v4i32 (the wider) and sext-widen the
;; v4i16 cmp.
define <4 x i32> @mixed_widths_pick_wider(<4 x i32> %a32, <4 x i32> %b32,
; CHECK-LABEL: define <4 x i32> @mixed_widths_pick_wider(
; CHECK-SAME: <4 x i32> [[A32:%.*]], <4 x i32> [[B32:%.*]], <4 x i16> [[A16:%.*]], <4 x i16> [[B16:%.*]], <4 x i32> [[X:%.*]], <4 x i32> [[Y:%.*]], i1 [[C:%.*]]) {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    [[CMP32:%.*]] = icmp eq <4 x i32> [[A32]], [[B32]]
; CHECK-NEXT:    [[CMP32_WIDE:%.*]] = sext <4 x i1> [[CMP32]] to <4 x i32>
; CHECK-NEXT:    [[CMP16:%.*]] = icmp eq <4 x i16> [[A16]], [[B16]]
; CHECK-NEXT:    [[CMP16_WIDE:%.*]] = sext <4 x i1> [[CMP16]] to <4 x i32>
; CHECK-NEXT:    [[AND_WIDE:%.*]] = and <4 x i32> [[CMP32_WIDE]], [[CMP16_WIDE]]
; CHECK-NEXT:    [[AND_NARROW:%.*]] = icmp slt <4 x i32> [[AND_WIDE]], zeroinitializer
; CHECK-NEXT:    br i1 [[C]], label %[[USE:.*]], label %[[OTHER:.*]]
; CHECK:       [[USE]]:
; CHECK-NEXT:    [[SEL:%.*]] = select <4 x i1> [[AND_NARROW]], <4 x i32> [[X]], <4 x i32> [[Y]]
; CHECK-NEXT:    ret <4 x i32> [[SEL]]
; CHECK:       [[OTHER]]:
; CHECK-NEXT:    ret <4 x i32> [[X]]
;
; DISABLE-LABEL: define <4 x i32> @mixed_widths_pick_wider(
; DISABLE-SAME: <4 x i32> [[A32:%.*]], <4 x i32> [[B32:%.*]], <4 x i16> [[A16:%.*]], <4 x i16> [[B16:%.*]], <4 x i32> [[X:%.*]], <4 x i32> [[Y:%.*]], i1 [[C:%.*]]) {
; DISABLE-NEXT:  [[ENTRY:.*:]]
; DISABLE-NEXT:    [[CMP32:%.*]] = icmp eq <4 x i32> [[A32]], [[B32]]
; DISABLE-NEXT:    [[CMP16:%.*]] = icmp eq <4 x i16> [[A16]], [[B16]]
; DISABLE-NEXT:    [[AND:%.*]] = and <4 x i1> [[CMP32]], [[CMP16]]
; DISABLE-NEXT:    br i1 [[C]], label %[[USE:.*]], label %[[OTHER:.*]]
; DISABLE:       [[USE]]:
; DISABLE-NEXT:    [[SEL:%.*]] = select <4 x i1> [[AND]], <4 x i32> [[X]], <4 x i32> [[Y]]
; DISABLE-NEXT:    ret <4 x i32> [[SEL]]
; DISABLE:       [[OTHER]]:
; DISABLE-NEXT:    ret <4 x i32> [[X]]
;
  <4 x i16> %a16, <4 x i16> %b16,
  <4 x i32> %x, <4 x i32> %y, i1 %c) {
entry:
  %cmp32 = icmp eq <4 x i32> %a32, %b32
  %cmp16 = icmp eq <4 x i16> %a16, %b16
  %and = and <4 x i1> %cmp32, %cmp16
  br i1 %c, label %use, label %other
use:
  %sel = select <4 x i1> %and, <4 x i32> %x, <4 x i32> %y
  ret <4 x i32> %sel
other:
  ret <4 x i32> %x
}

