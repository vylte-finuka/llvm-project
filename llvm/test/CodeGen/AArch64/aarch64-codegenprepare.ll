; DISABLE-LABEL: define <4 x i32> @length_changing_shuffle(
; DISABLE-SAME: <8 x float> [[A:%.*]], <8 x float> [[B:%.*]], <4 x i32> [[X:%.*]], <4 x i32> [[Y:%.*]], i1 [[C:%.*]]) {
; DISABLE-NEXT:  [[ENTRY:.*:]]
; DISABLE-NEXT:    [[CMP8:%.*]] = fcmp ole <8 x float> [[A]], [[B]]
; DISABLE-NEXT:    br i1 [[C]], label %[[L:.*]], label %[[R:.*]]
; DISABLE:       [[L]]:
; DISABLE-NEXT:    [[SHUF:%.*]] = shufflevector <8 x i1> [[CMP8]], <8 x i1> poison, <4 x i32> <i32 0, i32 1, i32 2, i32 3>
; DISABLE-NEXT:    br label %[[J:.*]]
; DISABLE:       [[R]]:
; DISABLE-NEXT:    br label %[[J]]
; DISABLE:       [[J]]:
; DISABLE-NEXT:    [[M:%.*]] = phi <4 x i1> [ [[SHUF]], %[[L]] ], [ zeroinitializer, %[[R]] ]
; DISABLE-NEXT:    [[SEL:%.*]] = select <4 x i1> [[M]], <4 x i32> [[X]], <4 x i32> [[Y]]
