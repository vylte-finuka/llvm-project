; DISABLE-SAME: ptr [[P:%.*]], <4 x i32> [[A:%.*]], <4 x i32> [[B:%.*]], <4 x i32> [[X:%.*]], <4 x i32> [[Y:%.*]], i1 [[C:%.*]]) {
; DISABLE-NEXT:  [[ENTRY:.*:]]
; DISABLE-NEXT:    [[X_I1:%.*]] = load <4 x i1>, ptr [[P]], align 1
; DISABLE-NEXT:    [[CMP:%.*]] = icmp eq <4 x i32> [[A]], [[B]]
; DISABLE-NEXT:    br i1 [[C]], label %[[L:.*]], label %[[R:.*]]
; DISABLE:       [[L]]:
; DISABLE-NEXT:    [[ANDL:%.*]] = and <4 x i1> [[CMP]], [[X_I1]]
; DISABLE-NEXT:    br label %[[J:.*]]
; DISABLE:       [[R]]:
; DISABLE-NEXT:    [[ANDR:%.*]] = and <4 x i1> [[CMP]], [[X_I1]]
; DISABLE-NEXT:    br label %[[J]]
