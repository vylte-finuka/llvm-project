rule CXX_STATIC_LIBRARY_LINKER__LLVMAArch64CodeGen_Release
  command = C:\WINDOWS\system32\cmd.exe /C "$PRE_LINK && D:\VisualS\VC\Tools\Llvm\x64\bin\llvm-lib.exe /nologo $LINK_FLAGS /out:$TARGET_FILE @$RSP_FILE && $POST_BUILD"
  description = Linking CXX static library $TARGET_FILE
  rspfile = $RSP_FILE
  rspfile_content = $in $LINK_PATH $LINK_LIBRARIES
  restat = $RESTAT


