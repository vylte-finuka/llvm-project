#############################################
# Rule for re-running cmake.

rule RERUN_CMAKE
  command = D:\Cmake\bin\cmake.exe --regenerate-during-build -SD:\Downloads\Vyft_product\Maratinelang\maratinec\llvm -BD:\Downloads\Vyft_product\Maratinelang\maratinec
  description = Re-running CMake...
  generator = 1


#############################################
# Rule for cleaning all built files.

rule CLEAN
  command = C:\Users\emmer\AppData\Local\Microsoft\WinGet\Links\ninja.exe $FILE_ARG -t clean $TARGETS
  description = Cleaning all built files...


#############################################
# Rule for printing all primary targets available.

rule HELP
  command = C:\Users\emmer\AppData\Local\Microsoft\WinGet\Links\ninja.exe -t targets
  description = All primary targets available:

