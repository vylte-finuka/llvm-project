rule RC_COMPILER__FileCheck_unscanned_Release
  depfile = $DEP_FILE
  deps = gcc
  command = ${LAUNCHER}${CODE_CHECK}D:\Cmake\bin\cmake.exe -E cmake_llvm_rc $in $out.pp D:\VisualS\VC\Tools\Llvm\x64\bin\clang-cl.exe $DEFINES -DRC_INVOKED $INCLUDES $FLAGS -clang:-MD -clang:-MF -clang:$DEP_FILE  -E -- $in ++ D:\VisualS\VC\Tools\Llvm\x64\bin\llvm-rc.exe $DEFINES -I SOURCE_DIR $INCLUDES $FLAGS -clang:-MD -clang:-MF -clang:$DEP_FILE /fo $out $out.pp
  description = Building RC object $out


#############################################
# Rule for linking CXX executable.

rule CXX_EXECUTABLE_LINKER__FileCheck_Release
  command = C:\WINDOWS\system32\cmd.exe /C "$PRE_LINK && D:\Cmake\bin\cmake.exe -E vs_link_exe --msvc-ver=1933 --intdir=$OBJECT_DIR --rc=D:\VisualS\VC\Tools\Llvm\x64\bin\llvm-rc.exe --mt=D:\VisualS\VC\Tools\Llvm\x64\bin\llvm-mt.exe --manifests $MANIFESTS -- D:\VisualS\VC\Tools\Llvm\x64\bin\lld-link.exe /nologo $in  /out:$TARGET_FILE /implib:$TARGET_IMPLIB /pdb:$TARGET_PDB /version:0.0 $LINK_FLAGS $LINK_PATH $LINK_LIBRARIES && $POST_BUILD"
  description = Linking CXX executable $TARGET_FILE
  restat = $RESTAT


