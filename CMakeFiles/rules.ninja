  command = C:\WINDOWS\system32\cmd.exe /C "$PRE_LINK && D:\Cmake\bin\cmake.exe -E vs_link_exe --msvc-ver=1933 --intdir=$OBJECT_DIR --rc=D:\VisualS\VC\Tools\Llvm\x64\bin\llvm-rc.exe --mt=D:\VisualS\VC\Tools\Llvm\x64\bin\llvm-mt.exe --manifests $MANIFESTS -- D:\VisualS\VC\Tools\Llvm\x64\bin\lld-link.exe /nologo $in  /out:$TARGET_FILE /implib:$TARGET_IMPLIB /pdb:$TARGET_PDB /version:0.0 $LINK_FLAGS $LINK_PATH $LINK_LIBRARIES && $POST_BUILD"
  description = Linking CXX executable $TARGET_FILE
  restat = $RESTAT


